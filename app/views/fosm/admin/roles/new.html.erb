<div class="p-6 space-y-6 max-w-2xl">
  <div class="flex items-center gap-3">
    <%= link_to "← Role Assignments", fosm.admin_roles_path, class: "text-sm text-blue-600 hover:underline" %>
  </div>

  <div>
    <h1 class="text-2xl font-bold text-gray-900">Grant Role</h1>
    <p class="text-sm text-gray-500 mt-1">
      Assign a lifecycle role to an actor. Type-level assignments apply to all records;
      record-level assignments apply to one specific record.
    </p>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-5">
    <%= form_with model: @assignment,
        url: fosm.admin_roles_path,
        class: "space-y-5" do |f| %>

      <% if @assignment.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
          <ul class="list-disc list-inside space-y-1">
            <% @assignment.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Hidden fields — populated by the autocomplete below %>
      <%= f.hidden_field :user_type, value: "User", id: "role_assignment_user_type" %>
      <%= f.hidden_field :user_id,   value: "",      id: "role_assignment_user_id" %>

      <div id="user-autocomplete" class="relative">
        <label class="block text-sm font-medium text-gray-700 mb-1">User</label>
        <input
          id="user-search-input"
          type="text"
          placeholder="Search by name or email…"
          autocomplete="off"
          class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500"
        />
        <div
          id="user-search-dropdown"
          class="absolute z-10 w-full mt-1 bg-white border border-gray-200 rounded shadow-lg hidden text-sm"
        ></div>
        <p class="text-xs text-gray-400 mt-1" id="user-search-hint">Type at least 2 characters to search</p>
      </div>

      <script>
        (function() {
          var searchInput    = document.getElementById('user-search-input');
          var dropdown       = document.getElementById('user-search-dropdown');
          var hiddenId       = document.getElementById('role_assignment_user_id');
          var hiddenType     = document.getElementById('role_assignment_user_type');
          var hint           = document.getElementById('user-search-hint');
          var searchUrl      = "<%= fosm.users_search_admin_roles_path %>";
          var debounceTimer  = null;

          function showDropdown(items) {
            dropdown.innerHTML = '';
            if (!items.length) {
              dropdown.innerHTML = '<div class="px-3 py-2 text-gray-400">No users found</div>';
            } else {
              items.forEach(function(item) {
                var el = document.createElement('div');
                el.className = 'px-3 py-2 cursor-pointer hover:bg-blue-50';
                el.textContent = item.label;
                el.addEventListener('mousedown', function(e) {
                  e.preventDefault();
                  selectUser(item);
                });
                dropdown.appendChild(el);
              });
            }
            dropdown.classList.remove('hidden');
          }

          function selectUser(item) {
            hiddenId.value      = item.id;
            searchInput.value   = item.label;
            hint.textContent    = 'Selected: ' + item.label;
            hint.classList.add('text-green-600');
            hint.classList.remove('text-gray-400');
            dropdown.classList.add('hidden');
          }

          function clearSelection() {
            hiddenId.value = '';
            hint.textContent = 'Type at least 2 characters to search';
            hint.classList.remove('text-green-600');
            hint.classList.add('text-gray-400');
          }

          searchInput.addEventListener('input', function() {
            var q = searchInput.value.trim();
            clearSelection();
            clearTimeout(debounceTimer);

            if (q.length < 2) {
              dropdown.classList.add('hidden');
              return;
            }

            debounceTimer = setTimeout(function() {
              var url = searchUrl + '?q=' + encodeURIComponent(q) + '&user_type=' + encodeURIComponent(hiddenType.value);
              fetch(url, { headers: { 'Accept': 'application/json' } })
                .then(function(r) { return r.json(); })
                .then(function(data) { showDropdown(data); })
                .catch(function() { dropdown.classList.add('hidden'); });
            }, 250);
          });

          searchInput.addEventListener('blur', function() {
            setTimeout(function() { dropdown.classList.add('hidden'); }, 150);
          });

          searchInput.addEventListener('focus', function() {
            if (dropdown.children.length > 0 && hiddenId.value === '') {
              dropdown.classList.remove('hidden');
            }
          });
        })();
      </script>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Resource Type</label>
        <%= f.select :resource_type,
            @apps.map { |_, klass| [klass.name.demodulize, klass.name] },
            { include_blank: "— Select a FOSM app —" },
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Resource ID <span class="text-gray-400 font-normal">(optional)</span></label>
        <%= f.text_field :resource_id,
            placeholder: "Leave blank for type-level (all records)",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        <p class="text-xs text-gray-400 mt-1">
          Blank = applies to <em>all</em> records of the selected type.
          Fill in = applies to one specific record only.
        </p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Role Name</label>
        <% role_options = @apps.flat_map { |_, klass|
             next [] unless klass.fosm_lifecycle&.access_defined?
             klass.fosm_lifecycle.access_definition.role_names.map { |rn|
               ["#{klass.name.demodulize} → :#{rn}", rn.to_s]
             }
           }.uniq(&:last) %>
        <% if role_options.any? %>
          <%= f.select :role_name,
              role_options,
              { include_blank: "— Select a role —" },
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        <% else %>
          <%= f.text_field :role_name,
              placeholder: "owner, approver, viewer…",
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        <% end %>
        <p class="text-xs text-gray-400 mt-1">Must match a role declared in the lifecycle <code>access</code> block.</p>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <%= f.submit "Grant Role",
            class: "bg-gray-900 text-white text-sm px-4 py-2 rounded hover:bg-gray-700 cursor-pointer" %>
        <%= link_to "Cancel", fosm.admin_roles_path,
            class: "text-sm text-gray-500 hover:underline" %>
      </div>
    <% end %>
  </div>

  <% if @apps.any? { |_, klass| klass.fosm_lifecycle&.access_defined? } %>
    <div class="bg-gray-50 border border-gray-100 rounded-lg p-4">
      <h3 class="text-sm font-medium text-gray-700 mb-2">Available roles per app</h3>
      <div class="space-y-2">
        <% @apps.each do |slug, klass| %>
          <% next unless klass.fosm_lifecycle&.access_defined? %>
          <div class="flex items-start gap-3 text-sm">
            <span class="text-gray-500 w-24 shrink-0"><%= klass.name.demodulize %></span>
            <div class="flex flex-wrap gap-1">
              <% klass.fosm_lifecycle.access_definition.roles.each do |role| %>
                <span class="text-xs font-mono bg-white border border-gray-200 text-gray-700 px-1.5 py-0.5 rounded">
                  :<%= role.name %>
                  &mdash; <%= role.all_permissions.join(", ") %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
